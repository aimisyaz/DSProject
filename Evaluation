recommend_movies <- function(movie_id, similarity_matrix, top_n = 5) {
  movie_id <- as.character(movie_id)
  if(!(movie_id %in% rownames(similarity_matrix))) return(NA)
  
  similarity_scores <- similarity_matrix[movie_id, ]
  sorted_scores <- sort(similarity_scores, decreasing = TRUE)
  recommended_movies <- names(sorted_scores)[2:(top_n + 1)]
  return(recommended_movies)
}

precision_at_k <- function(user_id, K = 5) {
  actual <- rating_data %>%
    filter(user_id == !!user_id, rating >= 4) %>%
    pull(item_id)
  if(length(actual) == 0) return(NA)
  recs <- recommend_movies(sample(actual, 1), movie_similarity_matrix, K)
  recs <- as.numeric(recs)
  relevant <- sum(recs %in% actual)
  return(relevant / K)
}

recall_at_k <- function(user_id, K = 5) {
  actual <- rating_data %>%
    filter(user_id == !!user_id, rating >= 4) %>%
    pull(item_id)
  if(length(actual) == 0) return(NA)
  recs <- recommend_movies(sample(actual, 1), movie_similarity_matrix, K)
  recs <- as.numeric(recs)
  relevant <- sum(recs %in% actual)
  return(relevant / length(actual))
}

users_sample <- sample(unique(rating_data$user_id), 20)
precision_list <- sapply(users_sample, precision_at_k)
recall_list <- sapply(users_sample, recall_at_k)

avg_precision <- mean(precision_list, na.rm = TRUE)
avg_recall <- mean(recall_list, na.rm = TRUE)

