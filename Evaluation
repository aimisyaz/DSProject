predict_rating <- function(user_id, movie_id, matrix_data, similarity_matrix) {
  user_id <- as.character(user_id)
  movie_id <- as.character(movie_id)
  
  if(!(user_id %in% rownames(matrix_data))) return(NA)
  if(!(movie_id %in% colnames(matrix_data))) return(NA)
  
  user_ratings <- matrix_data[user_id, ]
  similarities <- similarity_matrix[movie_id, ]
  
  rated_movies <- which(user_ratings > 0)
  if(length(rated_movies) == 0) return(NA)
  
  sim_scores <- similarities[rated_movies]
  ratings <- user_ratings[rated_movies]

  valid_idx <- !is.na(sim_scores)
  sim_scores <- sim_scores[valid_idx]
  ratings <- ratings[valid_idx]
  if(length(sim_scores) == 0) return(NA)
  if(sum(abs(sim_scores), na.rm = TRUE) == 0) return(NA)
  
  predicted <- sum(sim_scores * ratings) / sum(abs(sim_scores))
  return(predicted)
}

